# Auto Drive rclone configuration
#
# Auto Drive is permanent, immutable storage on the Autonomys Network.
# Get your API key at https://ai3.storage (Developers section).
#
# Usage:
#   rclone copy ./files/ autodrive:my-bucket/my-archive/ --immutable
#
# The first segment of the destination path is the bucket name.
# Buckets are created implicitly on first write - no setup required.
# Organize files using key prefixes (the path after the bucket name).

[autodrive]
type = s3
provider = Other
access_key_id = YOUR_API_KEY_HERE
secret_access_key = placeholder
endpoint = https://public.auto-drive.autonomys.xyz/s3
no_check_bucket = true

# For local development, use:
# endpoint = http://localhost:3000/s3
